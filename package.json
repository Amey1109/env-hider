{
  "name": "blurry-env",
  "displayName": "Blurry Env",
  "description": "Blurs out sensitive credentials in .env files with a single click.",
  "version": "0.0.5",
  "engines": {
    "vscode": "^1.90.0"
  },
  "publisher": "AmeyBhogaonkar",
  "license": "MIT",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:properties",
    "onLanguage:dotenv"
  ],
  "main": "./extension.js",
  "icon": "icon.png",
  "contributes": {
    "commands": [
      {
        "command": "blurry.toggleHide",
        "title": "Toggle Secrets Visibility",
        "icon": "$(eye)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "blurry.toggleHide",
          "group": "navigation",
          "when": "resourceLangId == properties || resourceLangId == dotenv"
        }
      ]
    }
  }
}